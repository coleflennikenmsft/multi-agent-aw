# Azure Blob Storage Configuration
# These environment variables are required for Azure Blob state management

# Option 1: Connection String (recommended for development)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<your-account-name>;AccountKey=<your-account-key>;EndpointSuffix=core.windows.net

# Option 2: Managed Identity (recommended for production)
# AZURE_STORAGE_ACCOUNT_NAME=<your-account-name>

# Container name (optional, default: workflow-context-state)
AZURE_STORAGE_CONTAINER_NAME=workflow-context-state
