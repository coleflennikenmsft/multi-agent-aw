# Azure Blob Storage Configuration for Workflow State Management

# Option 1: Use connection string (recommended for development/testing)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-storage-account;AccountKey=your-access-key;EndpointSuffix=core.windows.net

# Option 2: Use managed identity (recommended for production)
# AZURE_STORAGE_ACCOUNT_NAME=your-storage-account

# Optional: Specify custom container name (defaults to 'workflow-state')
# AZURE_STORAGE_CONTAINER_NAME=custom-container-name

# GitHub Actions Configuration (automatically set in Actions environment)
# GITHUB_RUN_ID=<unique-run-id>  # Used as workflow_id for state management